# Harkness Helper v2 — env template
#
# This file is the CANONICAL source of truth for which env vars the app reads.
# If you add a new env var in code, add it here in the same PR. If you rename
# one on Vercel, rename it here too. Project policy: `.env.example` is
# canonical; Vercel and code conform to it.
#
# Local dev: copy this file to .env.local and fill in values.
# Vercel:    set each var on the project's Settings → Environment Variables.

# ---- Supabase --------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Google SSO ------------------------------------------------------------
# Set up in Supabase dashboard → Auth → Providers → Google.
# The Workspace domain enforcement happens in /auth/callback against
# this allowlist; the `hd` OAuth hint alone isn't sufficient.
#
# CLIENT_ID + CLIENT_SECRET are the same OAuth client used by all 5 suite
# apps (converged 2026-05-15 per BUILD_PLAN M1.0). Needed server-side here
# so the googleapis SDK can refresh access tokens for Drive/Docs calls.
# Copy from a sibling repo's .env.local — they're shared values across
# the suite. The Supabase Google provider is configured with the same
# pair in its dashboard.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Public app URL --------------------------------------------------------
# Origin of this deployment, used to compose links.detail_url in outbound
# super-grader envelopes and any other place client code needs to render a
# canonical URL for the app. Local dev: http://localhost:3000. Vercel: the
# canonical production URL (e.g., https://harkness-helper-v2-sgs.vercel.app).
NEXT_PUBLIC_APP_URL=

# ---- Admin bootstrap -------------------------------------------------------
# First sign-in by this email gets auto-promoted to admin when the admins
# table is empty. Idempotent — once any admin exists, bootstrap won't fire.
INITIAL_ADMIN_EMAIL=hkoeze@episcopalhighschool.org

# Optional: enforce a domain on email entered into the "Grant admin" form.
ADMIN_EMAIL_DOMAIN=episcopalhighschool.org

# ---- Gemini (Phase C) ------------------------------------------------------
# Hugh's personal, EHS-paid key — same key (same var name) in super-grader,
# AI Documenter, Handwritten Helper, and Oral Examiner v2.
GEMINI_API_KEY=
GEMINI_DEFAULT_DAILY_CAP=15

# ---- Inngest (Phase C) -----------------------------------------------------
# Separate Inngest "app" for HK on the existing Inngest account. Get keys
# from app.inngest.com → harkness-helper app → Manage → Event Keys / Signing Key.
#
# LOCAL DEV: set INNGEST_DEV=1 (and leave the two key vars blank). Run
# `npx inngest-cli@latest dev` in another terminal — it auto-discovers
# /api/inngest at http://localhost:3000 and exposes its UI on :8288.
# Without INNGEST_DEV=1, v4 of the SDK assumes cloud mode and 500s on the
# /api/inngest route with "no signing key found."
#
# PRODUCTION (Vercel): leave INNGEST_DEV blank; set the two keys.
INNGEST_DEV=
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ---- Canvas (Phase B) ------------------------------------------------------
# Single-tenant tool — one teacher's Canvas credentials live here, not in
# the DB (HAH and AI Documenter store per-teacher tokens encrypted at rest
# because they're multi-tenant; HH isn't).
CANVAS_BASE_URL=
CANVAS_API_TOKEN=

# ---- Super Grader satellite integration (Phase D) ==========================
# HH is a "satellite" of Super Grader. Three secrets here are SHARED with
# the Super Grader project — they hold byte-identical values across
# projects, but each project NAMES them after who it's talking to.

# Anonymization salt — 32+ random bytes base64-encoded.
# SHARED VALUE across HH ↔ Super Grader ↔ AI Documenter ↔ Handwritten Helper
# ↔ Oral Examiner v2 (all use this same var name). Copy from a sibling
# project's env; never regenerate — invalidates every stored anon_token
# across the entire ecosystem.
SUPER_GRADER_SALT=

# Base URL of the Super Grader deployment. Code appends /api/ingest/harkness.
# Leave blank if Super Grader isn't deployed yet — webhook silently no-ops.
SUPER_GRADER_API_URL=

# Bearer HH presents on outbound POST to <SUPER_GRADER_API_URL>/api/ingest/harkness.
# SHARED VALUE with Super Grader, where the same value is named
# HARKNESS_INGEST_TOKEN (asymmetric naming on purpose: each side names
# after who it's talking to).
SUPER_GRADER_INGEST_TOKEN=

# Bearer Super Grader presents on inbound GET /api/super-grader/* requests.
# SHARED VALUE with Super Grader (same var name on both sides).
HARKNESS_API_TOKEN=

# ---- Sentry (Phase E — optional; leave blank to disable error reporting) --
SENTRY_DSN=
# Browser DSN — must be public-prefixed since it ships to the client bundle.
NEXT_PUBLIC_SENTRY_DSN=
